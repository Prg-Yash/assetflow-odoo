{
  "name": "worker",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/queues/ tests/processors/ tests/services/ tests/cron/",
    "test:integration": "vitest run tests/integration/",
    "test:e2e": "vitest run tests/integration/worker.spec.ts",
    "test:worker": "vitest run tests/integration/worker.spec.ts",
    "test:queues": "vitest run tests/queues/",
    "test:notifications": "vitest run tests/services/notification.spec.ts",
    "test:cron": "vitest run tests/cron/",
    "test:performance": "vitest run tests/performance/"
  },
  "dependencies": {
    "@repo/db": "*",
    "bullmq": "^5.41.3",
    "dotenv": "^16.4.7",
    "nodemailer": "^6.9.16",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/nodemailer": "^6.4.17",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.39.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.3",
    "typescript": "5.9.2",
    "vitest": "^2.1.8"
  }
}
